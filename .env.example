# Application
APP_ENV=local
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sistem Rekonsiliasi Stok
NEXT_PUBLIC_APP_MODE=LOCAL
NEXT_PUBLIC_APP_VERSION=dev
NEXT_PUBLIC_TIMEZONE=Asia/Jakarta

# Supabase browser-safe configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Supabase server-only configuration
# Never expose this value to browser code or commit a real key.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Optional direct database connections for server-side tooling
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Marketplace simulator
MARKETPLACE_SIMULATOR_ENABLED=true
