# ==============================================================================
# .env.example
# Sistem Rekonsiliasi Stok
#
# Salin file ini:
#   cp .env.example .env.local
#
# Lalu ambil nilai Supabase lokal dengan:
#   supabase start
#   supabase status
#
# Aturan:
# - File ini hanya berisi placeholder dan default non-rahasia.
# - Jangan commit .env.local, .env.production, atau file secret lain.
# - Variable NEXT_PUBLIC_* masuk ke bundle browser saat build.
# - SUPABASE_SECRET_KEY dan legacy SUPABASE_SERVICE_ROLE_KEY melewati RLS.
#   Keduanya hanya boleh digunakan pada trusted server/worker.
# - Production, preview/staging, demo, dan local harus memakai secret terpisah.
# ==============================================================================


# ==============================================================================
# 1. APPLICATION
# ==============================================================================

# Environment aplikasi.
# Nilai yang didukung:
#   local | test | preview | demo | production
#
# Jangan memakai NODE_ENV=staging/demo. Next.js mengelola NODE_ENV sendiri.
APP_ENV=local

# URL kanonis aplikasi pada environment ini.
# Production:
#   https://stock.example.com
APP_BASE_URL=http://localhost:3000

# Mode maintenance server-side.
# Nilai:
#   off | read-only
APP_MAINTENANCE_MODE=off

# Nama yang aman ditampilkan di browser.
NEXT_PUBLIC_APP_NAME=Sistem Rekonsiliasi Stok

# Label UI environment.
# Nilai yang direkomendasikan:
#   LOCAL | TEST | PREVIEW | DEMO | PRODUCTION
NEXT_PUBLIC_APP_MODE=LOCAL

# Versi aplikasi yang aman ditampilkan pada diagnostics.
# Pada CI/Vercel dapat diisi commit SHA atau release version.
NEXT_PUBLIC_APP_VERSION=dev

# Zona waktu bisnis.
# Timestamp database tetap disimpan sebagai timestamptz/UTC.
NEXT_PUBLIC_TIMEZONE=Asia/Jakarta


# ==============================================================================
# 2. SUPABASE — BROWSER-SAFE
# ==============================================================================

# URL API Supabase.
# Local default biasanya:
#   http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Key publik Supabase terbaru.
# Format hosted:
#   sb_publishable_...
#
# Key ini aman berada di browser HANYA jika RLS dan grants benar.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME


# ==============================================================================
# 3. SUPABASE — SERVER-ONLY PRIVILEGED KEY
# ==============================================================================

# Secret key Supabase terbaru.
# Format:
#   sb_secret_...
#
# SERVER-ONLY.
# Key ini dapat melewati RLS dan hanya dipakai untuk kebutuhan terbatas seperti:
# - Auth Admin invite/deactivate/revoke session;
# - worker administratif yang benar-benar membutuhkan privilege;
# - maintenance terkontrol.
#
# Jangan digunakan sebagai client default untuk request user biasa.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Legacy fallback, hanya bila project belum bermigrasi ke key terbaru.
# Deprecated path; hapus setelah code sepenuhnya memakai SUPABASE_SECRET_KEY.
#
# SERVER-ONLY dan melewati RLS.
# SUPABASE_SERVICE_ROLE_KEY=eyJ_REPLACE_LEGACY_SERVICE_ROLE_KEY


# ==============================================================================
# 4. POSTGRES CONNECTIONS — SERVER/CI ONLY
# ==============================================================================

# URL pooled untuk runtime serverless bila aplikasi memang memakai direct SQL.
# Untuk sebagian besar request, gunakan user-scoped Supabase client + RPC/RLS.
#
# Local Supabase biasanya menggunakan port Postgres 54322.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# URL direct untuk migration, administration, atau tooling yang memerlukan
# koneksi langsung. Jangan digunakan di browser.
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ==============================================================================
# 5. MARKETPLACE SIMULATOR
# ==============================================================================

# Local/test/demo:
#   true
#
# Production:
#   false
MARKETPLACE_SIMULATOR_ENABLED=true

# Mengizinkan simulator memproses event melalui canonical domain pipeline.
# Dry-run tetap dapat tersedia ketika nilai ini false.
MARKETPLACE_SIMULATOR_ALLOW_COMMIT=true

# Batas jumlah event dalam satu simulator run.
MARKETPLACE_SIMULATOR_MAX_EVENTS_PER_RUN=50

# Organization demo deterministik dari seed.sql.
# Simulator harus menolak organisasi lain.
MARKETPLACE_SIMULATOR_DEMO_ORG_ID=00000000-0000-4000-8000-000000000001


# ==============================================================================
# 6. DEPLOYMENT METADATA
# ==============================================================================

# Fallback metadata untuk local/non-Vercel.
# Di Vercel, aplikasi dapat membaca VERCEL_ENV, VERCEL_URL, dan
# VERCEL_GIT_COMMIT_SHA yang disediakan platform.
DEPLOYMENT_ENV=local
DEPLOYMENT_COMMIT_SHA=local
DEPLOYMENT_URL=http://localhost:3000

# Vercel system variables berikut biasanya diinjeksi otomatis.
# Jangan diisi manual pada .env.local kecuali sedang menguji adapter metadata.
#
# VERCEL_ENV=
# VERCEL_TARGET_ENV=
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
# VERCEL_GIT_COMMIT_SHA=


# ==============================================================================
# 7. OBSERVABILITY
# ==============================================================================

# Level log:
#   trace | debug | info | warn | error
#
# Production direkomendasikan:
#   info
LOG_LEVEL=debug

# Optional error-monitoring DSN, server-side.
# Kosongkan bila provider belum dipilih.
SENTRY_DSN=

# Optional DSN yang memang aman diekspos ke browser.
# Jangan menyalin secret credential server ke variable ini.
NEXT_PUBLIC_SENTRY_DSN=


# ==============================================================================
# 8. LOCAL E2E / DEMO AUTOMATION
# ==============================================================================

# Digunakan Playwright atau test harness.
E2E_BASE_URL=http://localhost:3000

# Akun sintetis yang direkomendasikan seed/demo.
# User Auth harus dibuat melalui trusted Auth Admin API atau local Studio.
E2E_ADMIN_EMAIL=demo.admin@glowlab.invalid

# Placeholder saja. Jangan commit password sungguhan.
E2E_ADMIN_PASSWORD=REPLACE_WITH_LOCAL_TEST_PASSWORD


# ==============================================================================
# 9. CI/CD-ONLY SECRETS
# ==============================================================================
#
# Variable berikut biasanya disimpan pada GitHub Actions Environments,
# Vercel project settings, atau secret manager. Jangan menaruh nilai nyata di
# .env.local kecuali workflow lokal benar-benar memerlukannya.
#
# Supabase CLI deployment:
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_ID=
#
# Optional split per environment:
# SUPABASE_STAGING_PROJECT_ID=
# SUPABASE_PRODUCTION_PROJECT_ID=
#
# Vercel CLI deployment:
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=


# ==============================================================================
# 10. PRODUCTION REFERENCE
# ==============================================================================
#
# Gunakan bagian ini sebagai panduan Vercel Production Environment, BUKAN
# sebagai nilai local yang langsung diaktifkan.
#
# APP_ENV=production
# APP_BASE_URL=https://stock.example.com
# APP_MAINTENANCE_MODE=off
# NEXT_PUBLIC_APP_MODE=PRODUCTION
# NEXT_PUBLIC_APP_VERSION=<release-or-commit-sha>
# NEXT_PUBLIC_TIMEZONE=Asia/Jakarta
#
# NEXT_PUBLIC_SUPABASE_URL=https://<production-project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<production>
# SUPABASE_SECRET_KEY=sb_secret_<production>
#
# DATABASE_URL=<production-pooled-postgres-url>
# DIRECT_URL=<production-direct-postgres-url>
#
# MARKETPLACE_SIMULATOR_ENABLED=false
# MARKETPLACE_SIMULATOR_ALLOW_COMMIT=false
# MARKETPLACE_SIMULATOR_MAX_EVENTS_PER_RUN=0
# MARKETPLACE_SIMULATOR_DEMO_ORG_ID=
#
# DEPLOYMENT_ENV=production
# DEPLOYMENT_COMMIT_SHA=<commit-sha>
# DEPLOYMENT_URL=https://stock.example.com
# LOG_LEVEL=info
#
# Production juga wajib dikonfigurasi di dashboard/provider:
# - Supabase public signup disabled;
# - invite-only Admin accounts;
# - custom SMTP;
# - MFA/AAL2 untuk tindakan sensitif;
# - private Storage buckets;
# - RLS dan grants;
# - Auth Site URL serta Redirect URLs;
# - Cron dan job health;
# - backup/PITR sesuai keputusan operasional.
